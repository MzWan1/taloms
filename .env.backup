# ===== DATABASE =====
spring.datasource.url=jdbc:postgresql://${DB_HOST:localhost}:${DB_PORT:5432}/${DB_NAME:taloms_db}
spring.datasource.username=${DB_USERNAME:taloms_user}
spring.datasource.password=${DB_PASSWORD:taloms_pass}
spring.datasource.driver-class-name=org.postgresql.Driver

# ===== HIKARI =====
spring.datasource.hikari.connection-timeout=30000
spring.datasource.hikari.idle-timeout=600000
spring.datasource.hikari.max-lifetime=1800000
spring.datasource.hikari.maximum-pool-size=5

# ===== JPA =====
spring.jpa.hibernate.ddl-auto=validate
spring.jpa.show-sql=false
spring.jpa.properties.hibernate.dialect=org.hibernate.dialect.PostgreSQLDialect
spring.jpa.open-in-view=false

# ===== FLYWAY =====
spring.flyway.enabled=true
spring.flyway.locations=classpath:db/migration
spring.flyway.baseline-on-migrate=true
spring.flyway.validate-migration-naming=true

# ===== THYMELEAF =====
spring.thymeleaf.cache=false
spring.thymeleaf.check-template-location=false
spring.thymeleaf.prefix=classpath:/templates/
spring.thymeleaf.suffix=.html
spring.thymeleaf.encoding=UTF-8

# ===== SERVER =====
server.port=8080

# ===== LOGGING =====
logging.level.za.co.taloms=DEBUG
logging.level.org.springframework.security=INFO
logging.level.org.flywaydb=INFO

# ===== JWT =====
taloms.jwt.secret=${JWT_SECRET:404E635266556A586E3272357538782F413F4428472B4B6250645367566B5970}
taloms.jwt.expiration=${JWT_EXPIRATION:28800000}

# ===== REMEMBER ME =====
taloms.remember-me.key=TalomsRememberMeSecretKey2026
taloms.remember-me.validity=604800

# ===== EMAIL =====
spring.mail.host=${EMAIL_HOST:smtp.gmail.com}
spring.mail.port=${EMAIL_PORT:587}
spring.mail.username=${EMAIL_USERNAME:nkambulemm0@gmail.com}
spring.mail.password=${EMAIL_PASSWORD:wqctcwnfglglqskn}
spring.mail.properties.mail.smtp.auth=true
spring.mail.properties.mail.smtp.starttls.enable=true
spring.mail.properties.mail.smtp.starttls.required=true

# ===== APP =====
taloms.app.base-url=${APP_BASE_URL:http://localhost:8080}
taloms.upload.path=${APP_UPLOAD_PATH:uploads}

# ===== DATE FORMAT =====
spring.mvc.format.date=iso